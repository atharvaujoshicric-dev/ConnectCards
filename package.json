{
  "name": "connect-cards",
  "version": "1.0.0",
  "private": true,
  "description": "Connect Cards — Premium NFC-powered Digital Identity Platform",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:migrate:new": "supabase migration new",
    "supabase:migrate:up": "supabase migration up",
    "supabase:gen:types": "supabase gen types typescript --local > packages/types/src/database.types.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "next": "15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@supabase/supabase-js": "2.47.10",
    "@supabase/ssr": "0.5.2",
    "zod": "3.24.1",
    "react-hook-form": "7.54.2",
    "@hookform/resolvers": "3.9.1",
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.0",
    "class-variance-authority": "0.7.1",
    "lucide-react": "0.469.0",
    "framer-motion": "11.15.0",
    "@lottiefiles/dotlottie-react": "0.19.9",
    "recharts": "2.15.0",
    "date-fns": "4.1.0",
    "qrcode": "1.5.4",
    "react-qr-code": "2.0.15",
    "stripe": "17.5.0",
    "razorpay": "2.9.5",
    "resend": "4.0.1",
    "@react-email/components": "0.0.32",
    "@react-email/render": "1.0.3",
    "sharp": "0.33.5",
    "nanoid": "5.0.9",
    "pdf-lib": "1.17.1",
    "papaparse": "5.4.1",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.6",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-slot": "1.1.1",
    "sonner": "1.7.1",
    "next-themes": "0.4.4",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "@types/node": "22.10.5",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.2",
    "@types/qrcode": "1.5.5",
    "@types/papaparse": "5.3.15",
    "tailwindcss": "3.4.17",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "tailwindcss-animate": "1.0.7",
    "@tailwindcss/typography": "0.5.15",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-tailwindcss": "3.17.5",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "vitest": "2.1.8",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "@testing-library/react": "16.1.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/user-event": "14.5.2",
    "jsdom": "25.0.1",
    "@playwright/test": "1.55.0",
    "supabase": "1.226.4",
    "husky": "9.1.7",
    "lint-staged": "15.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{md,json}": ["prettier --write"]
  }
}
